		<Item class="ModuleScript" referent="RBX8BC3729BE9AA4B8DAECD639E9646B894">
			<Properties>
				<Content name="LinkedSource"><null></null></Content>
				<ProtectedString name="Source"><![CDATA[local ServerStorage = game:GetService("ServerStorage")
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local PhysicsService = game:GetService("PhysicsService")

-- Carrega o sistema de vida do castelo
local Base = require(script.Parent.Base)

local mob = {}

-- ============================================
-- CONFIGURAÇÕES (modifique aqui para ajustar o jogo)
-- ============================================
mob.Config = {
	tempoEntreSpawns = 1.5,   -- Segundos entre cada esqueleto spawnar
	velocidadeBase = 5,      -- Velocidade normal dos esqueletos
	esqueletosOnda1 = 6,        -- Quantidade de esqueletos na primeira onda
	aumentoPorOnda = 3,     -- Quantos zumbis a mais por onda
	aumentoVelocidade = 0.3, -- Zumbis ficam 30% mais rápidos por onda
	danoZumbi = 10,         -- Dano que o zumbi causa nas torres
	intervaloAtaque = 1.0,   -- Intervalo entre ataques (segundos)
}

-- ============================================
-- FUNÇÃO INTERNA: Move o zumbi pelo caminho
-- ============================================
local function moverZumbi(zumbi, mapa, dano)
	-- Debug: Mostra qual mob está se movendo e o dano
	local nomeMob = zumbi and zumbi.Name or "Desconhecido"
	print(string.format("[Mob] %s iniciando movimento (dano: %d)", nomeMob, dano or 10))
	
	-- Proteção contra erros
	local sucesso, erro = pcall(function()
		local humanoide = zumbi:FindFirstChild("Humanoid")
		local caminho = mapa:FindFirstChild("waypoints")
		
		-- Se não tem humanoide ou caminho, não faz nada
		if not humanoide or not caminho then return end

		-- Pega todos os pontos do caminho e ordena (1, 2, 3...)
		-- Filtra apenas partes com nomes numéricos
		local pontos = {}
		for _, filho in caminho:GetChildren() do
			if tonumber(filho.Name) then
				table.insert(pontos, filho)
			end
		end
		table.sort(pontos, function(a, b) 
			return tonumber(a.Name) < tonumber(b.Name) 
		end)

		-- Move o zumbi de ponto em ponto
		for i, ponto in pontos do
			-- Verifica se o zumbi ainda existe e está vivo
			if not zumbi or not zumbi.Parent then return end
			if not humanoide or humanoide.Health <= 0 then return end
			
			if ponto:IsA("BasePart") then
				humanoide:MoveTo(ponto.Position)
				humanoide.MoveToFinished:Wait(10)
				
				-- Verifica se chegou perto o suficiente do último waypoint
				local raiz = zumbi:FindFirstChild("HumanoidRootPart")
				local ehUltimoPonto = (i == #pontos)
				local distancia = raiz and (raiz.Position - ponto.Position).Magnitude or 0
				
				-- Se é o último ponto, espera até chegar perto o suficiente
				if ehUltimoPonto then
					local timeoutMaximo = 30 -- Tempo máximo de espera (30 segundos)
					local tempoInicio = tick()
					
					-- Espera até estar perto o suficiente (ou timeout)
					while distancia >= 5 and zumbi and zumbi.Parent and humanoide and humanoide.Health > 0 do
						if tick() - tempoInicio > timeoutMaximo then
							print(string.format("[Mob] %s timeout no último waypoint, forçando dano", nomeMob))
							break
						end
						task.wait(0.5)
						distancia = raiz and (raiz.Position - ponto.Position).Magnitude or 0
					end
					
					-- Causa dano ao castelo
					print(string.format("[Mob] %s chegou ao final! Causando %d de dano", nomeMob, dano or 10))
					Base.TakeDamage(dano or 10)
					if zumbi and zumbi.Parent then
						zumbi:Destroy()
					end
					return
				end
			end
		end
		
		-- Fallback: se completou todos os pontos mas não chegou perto do último
		if zumbi and zumbi.Parent then
			zumbi:Destroy()
		end
	end)
	
	-- Log de erros para debug
	if not sucesso then
		warn("Erro no moverZumbi: " .. tostring(erro))
	end
end

-- ============================================
-- FUNÇÃO: Spawna UM zumbi
-- ============================================
function mob.Spawn(nome, mapa, multiplicadorVelocidade, multiplicadorVida)
	-- 1. Encontra o modelo do zumbi no ServerStorage
	local pasta = ServerStorage:FindFirstChild("Mobs")
	local modelo = pasta and pasta:FindFirstChild(nome)
	if not modelo then return end  -- Se não encontrou, sai da função

	-- 2. Cria uma cópia do zumbi
	local zumbi = modelo:Clone()

	-- 3. Posiciona no ponto de início do mapa
	local inicio = mapa:FindFirstChild("Start")
	local raiz = zumbi:FindFirstChild("HumanoidRootPart")  -- Parte que controla posição
	
	if inicio and raiz then
		raiz.CFrame = inicio.CFrame
	end

	-- 3.5 Define a velocidade ANTES de colocar no Workspace (primeira definição)
	local humanoide = zumbi:FindFirstChild("Humanoid")
	local velocidadeFinal = mob.Config.velocidadeBase * (multiplicadorVelocidade or 1)
	
	-- Aplica multiplicador de vida (se fornecido)
	local vidaFinal = humanoide and humanoide.MaxHealth * (multiplicadorVida or 1) or nil
	
	if humanoide then
		humanoide.WalkSpeed = velocidadeFinal
		if multiplicadorVida and multiplicadorVida ~= 1 then
			humanoide.MaxHealth = vidaFinal
			humanoide.Health = vidaFinal
		end
	end

	-- 4. Aplica grupo de colisão (não colide com players)
	for _, part in zumbi:GetDescendants() do
		if part:IsA("BasePart") then
			part.CollisionGroup = "Mobs"
			-- Garante que partes móveis não estejam ancoradas
			part.Anchored = false
			-- Configura propriedades de física para movimento suave
			part.CanCollide = true
			part.Massless = false
		end
	end

	-- 5. Garante que o modelo tem PrimaryPart definido
	if not zumbi.PrimaryPart then
		zumbi.PrimaryPart = raiz
	end

	-- 6. Coloca no mundo PRIMEIRO (necessário para Network Ownership)
	zumbi.Parent = workspace

	-- 7. Network Ownership: NPCs devem ser controlados pelo servidor
	-- Isso garante movimento consistente e evita exploits
	-- IMPORTANTE: Só pode ser chamado depois que o modelo está no Workspace
	for _, part in zumbi:GetDescendants() do
		if part:IsA("BasePart") then
			part:SetNetworkOwner(nil)  -- nil = servidor tem controle
		end
	end

	-- 8. Redefine a velocidade DEPOIS de colocar no Workspace (garante valor correto)
	-- Isso evita que o Humanoid reinicialize a velocidade para o padrão
	if humanoide then
		humanoide.WalkSpeed = velocidadeFinal
	end

	-- 9. Define o dano baseado no tipo de mob
	local dano = 10  -- Padrão: Dark Skeleton
	if nome == "Golem" then
		dano = 30  -- Golem causa 30 de dano
	end
	
	print(string.format("[Spawn] %s spawnado (dano: %d, velocidade: %.1f)", nome, dano, velocidadeFinal))
	
	-- 10. Começa a andar
	task.spawn(moverZumbi, zumbi, mapa, dano)
end

-- ============================================
-- FUNÇÃO: Spawna VÁRIOS zumbis (uma onda)
-- ============================================
function mob.SpawnWave(nome, mapa, quantidade, multiplicadorVelocidade, multiplicadorVida)
	for i = 1, quantidade do
		-- Espera ANTES de spawnar (exceto o primeiro)
		if i > 1 then
			task.wait(mob.Config.tempoEntreSpawns)
		end
		mob.Spawn(nome, mapa, multiplicadorVelocidade, multiplicadorVida)
	end
end

-- ============================================
-- FUNÇÃO: Calcula quantos zumbis e qual velocidade para cada onda
-- ============================================
function mob.CalcularOnda(numeroOnda)
	-- Fórmula: zumbis base + (onda - 1) * aumento por onda
	local quantidade = mob.Config.esqueletosOnda1 + (numeroOnda - 1) * mob.Config.aumentoPorOnda
	
	-- Fórmula: 1 + (onda - 1) * aumento de velocidade
	local velocidade = 1 + (numeroOnda - 1) * mob.Config.aumentoVelocidade
	
	return quantidade, velocidade
end

-- ============================================
-- FUNÇÃO: Calcula multiplicador de HP do Dark Skeleton por onda
-- A partir da onda 4: +5 HP por onda
-- ============================================
function mob.CalcularSkeletonHP(numeroOnda)
	-- HP base do Dark Skeleton
	local hpBase = 30
	
	-- Antes da onda 4: sem bônus
	if numeroOnda < 4 then
		return 1
	end
	
	-- A partir da onda 4: +5 HP por onda
	-- Onda 4: +5 HP, Onda 5: +10 HP, Onda 6: +15 HP
	local bonusHP = (numeroOnda - 3) * 5
	local multiplicador = (hpBase + bonusHP) / hpBase
	
	return multiplicador
end

-- ============================================
-- FUNÇÃO: Calcula multiplicadores do Golem por onda
-- Velocidade: FIXA (não aumenta)
-- Vida: +10% por onda (começando da onda 4)
-- ============================================
function mob.CalcularGolemStats(numeroOnda)
	if numeroOnda < 4 then
		return 1, 1 -- Sem bônus antes da onda 4
	end
	
	-- Calcula quantas ondas se passaram desde a onda 4
	local ondasDesdeInicio = numeroOnda - 4
	
	-- Velocidade: FIXA (sem aumento por onda)
	local multiplicadorVelocidade = 1
	
	-- Vida: 1.1^ondasDesdeInicio (10% por onda)
	local multiplicadorVida = 1.1 ^ ondasDesdeInicio
	
	return multiplicadorVelocidade, multiplicadorVida
end

-- ============================================
-- FUNÇÃO: Conta quantos zumbis estão vivos
-- (exclui jogadores e torres, conta apenas inimigos)
-- ============================================
function mob.ContarVivos()
	local contador = 0
	local mobsVivos = {}
	
	for _, objeto in workspace:GetChildren() do
		local humanoide = objeto:FindFirstChild("Humanoid")
		local naoEhJogador = not Players:GetPlayerFromCharacter(objeto)
		local naoEhTorre = not objeto:FindFirstChild("GladiatorScript")
		
		-- Só conta se: tem Humanoid, não é jogador, não é torre, e está VIVO
		if humanoide and naoEhJogador and naoEhTorre and humanoide.Health > 0 then
			contador += 1
			table.insert(mobsVivos, objeto.Name)
		end
	end
	
	-- Debug: mostra quais mobs estão vivos
	if contador > 0 then
		print(string.format("[ContarVivos] %d mobs vivos: %s", contador, table.concat(mobsVivos, ", ")))
	end
	
	return contador
end

return mob]]></ProtectedString>
				<string name="ScriptGuid">{4BD73413-FE50-4D50-A642-AF225A718C0D}</string>
