		<Item class="Script" referent="RBX0369DB2EF1E54AF6A84E9E0AE4462FEE">
			<Properties>
				<ProtectedString name="Source"><![CDATA[local ReplicatedStorage = game:GetService("ReplicatedStorage")

-- Referência ao RemoteEvent
local placeTowerEvent = ReplicatedStorage:WaitForChild("PlaceTower")

-- Referência ao modelo da torre Gladiator
local gladiatorModel = ReplicatedStorage:WaitForChild("Towers"):WaitForChild("Gladiator")
local mapa = workspace:WaitForChild("cenario")

-- Configurações
local PATH_BLOCK_RADIUS = 4 -- Mesmo valor do cliente
local MIN_PLAYER_DISTANCE = 4 -- Distância mínima do jogador
local MIN_SPAWN_DISTANCE = 9 -- Distância mínima do spawn dos mobs
local CASTLE_MARGIN = 2 -- Margem extra ao redor do castelo

-- Calcula distância de um ponto a uma linha (segmento)
local function distanceToSegment(point, lineStart, lineEnd)
	local px, pz = point.X, point.Z
	local x1, z1 = lineStart.X, lineStart.Z
	local x2, z2 = lineEnd.X, lineEnd.Z
	
	local dx = x2 - x1
	local dz = z2 - z1
	
	if dx == 0 and dz == 0 then
		return math.sqrt((px - x1)^2 + (pz - z1)^2)
	end
	
	local t = ((px - x1) * dx + (pz - z1) * dz) / (dx * dx + dz * dz)
	t = math.clamp(t, 0, 1)
	
	local nearestX = x1 + t * dx
	local nearestZ = z1 + t * dz
	
	return math.sqrt((px - nearestX)^2 + (pz - nearestZ)^2)
end

-- Verifica se posição está no caminho dos inimigos (mesma lógica do cliente)
local function isOnPath(position)
	local waypoints = mapa:FindFirstChild("waypoints")
	if not waypoints then return false end
	
	-- Coleta e ordena waypoints
	local pontos = {}
	for _, wp in waypoints:GetChildren() do
		if wp:IsA("BasePart") and tonumber(wp.Name) then
			table.insert(pontos, {name = tonumber(wp.Name), pos = wp.Position})
		end
	end
	table.sort(pontos, function(a, b) return a.name < b.name end)
	
	-- Adiciona o ponto de início (Start) no começo do caminho
	local startPart = mapa:FindFirstChild("Start")
	if startPart and startPart:IsA("BasePart") then
		table.insert(pontos, 1, {name = 0, pos = startPart.Position})
	end
	
	-- Verifica distância para cada waypoint
	for _, ponto in pontos do
		local dist2D = math.sqrt((position.X - ponto.pos.X)^2 + (position.Z - ponto.pos.Z)^2)
		if dist2D < PATH_BLOCK_RADIUS then
			return true
		end
	end
	
	-- Verifica distância para cada segmento do caminho
	for i = 1, #pontos - 1 do
		local dist = distanceToSegment(position, pontos[i].pos, pontos[i + 1].pos)
		if dist < PATH_BLOCK_RADIUS then
			return true
		end
	end
	
	return false
end

-- Verifica se está em cima do jogador
local function isOnPlayer(player, position)
	local character = player.Character
	if not character then return false end
	
	local hrp = character:FindFirstChild("HumanoidRootPart")
	if not hrp then return false end
	
	local dist2D = math.sqrt((position.X - hrp.Position.X)^2 + (position.Z - hrp.Position.Z)^2)
	return dist2D < MIN_PLAYER_DISTANCE
end

-- Verifica se está muito perto do spawn dos mobs
local function isTooCloseToSpawn(position)
	local startPart = mapa:FindFirstChild("Start")
	if not startPart or not startPart:IsA("BasePart") then return false end
	
	local dist2D = math.sqrt((position.X - startPart.Position.X)^2 + (position.Z - startPart.Position.Z)^2)
	return dist2D < MIN_SPAWN_DISTANCE
end

-- Verifica se está em cima do Castelo (Base)
local function isOnCastle(position)
	local cenario = mapa:FindFirstChild("Cenário")
	if not cenario then return false end
	
	local castelo1 = cenario:FindFirstChild("Castelo1")
	if not castelo1 then return false end
	
	local castelo = castelo1:FindFirstChild("Castelo")
	if not castelo then return false end
	
	-- Pega o bounding box do castelo
	local cframe, size = castelo:GetBoundingBox()
	local pos = cframe.Position
	
	-- Verifica se a posição está dentro da área do castelo (com margem)
	local halfSizeX = size.X / 2 + CASTLE_MARGIN
	local halfSizeZ = size.Z / 2 + CASTLE_MARGIN
	
	local withinX = math.abs(position.X - pos.X) < halfSizeX
	local withinZ = math.abs(position.Z - pos.Z) < halfSizeZ
	
	return withinX and withinZ
end

-- Função para configurar o gladiador após spawn
local function configurarGladiator(model)
	-- Configura o Humanoid para não pular e ficar estável
	local humanoid = model:FindFirstChildOfClass("Humanoid")
	if humanoid then
		humanoid.AutoJumpEnabled = false
		humanoid.JumpHeight = 0
		humanoid.JumpPower = 0
		humanoid.AutoRotate = false
		humanoid.PlatformStand = true -- Desativa controle de movimento do Humanoid
		humanoid.HipHeight = 0 -- R6 usa as pernas para altura
	end
	
	-- Ancora o HumanoidRootPart para não cair
	local hrp = model:FindFirstChild("HumanoidRootPart")
	if hrp then
		hrp.Anchored = true
	end
	
	-- Aplica grupo de colisão a todas as partes
	for _, part in model:GetDescendants() do
		if part:IsA("BasePart") then
			part.CollisionGroup = "Gladiators"
		end
	end
end

-- Função para spawnar a torre
local function spawnTower(player, towerName, position, rotation)
	-- Verifica se a torre existe
	local towerModel = ReplicatedStorage:FindFirstChild("Towers")
	if not towerModel then return end
	
	local tower = towerModel:FindFirstChild(towerName)
	if not tower then return end
	
	-- Verifica se posição está no caminho (segurança)
	if isOnPath(position) then
		print("Posição bloqueada: está no caminho dos inimigos")
		return
	end
	
	-- Verifica se está em cima do jogador (segurança)
	if isOnPlayer(player, position) then
		print("Posição bloqueada: está em cima do jogador")
		return
	end
	
	-- Verifica se está muito perto do spawn dos mobs
	if isTooCloseToSpawn(position) then
		print("Posição bloqueada: está muito perto do spawn dos mobs")
		return
	end
	
	-- Verifica se está em cima do castelo
	if isOnCastle(position) then
		print("Posição bloqueada: está em cima do castelo")
		return
	end
	
	-- Clona a torre
	local newTower = tower:Clone()
	
	-- Posiciona a torre com rotação
	local rotationRad = math.rad(rotation or 0)
	newTower:PivotTo(CFrame.new(position) * CFrame.Angles(0, rotationRad, 0))
	
	-- Configura o gladiador (colisão e humanoid)
	configurarGladiator(newTower)
	
	-- Coloca no Workspace
	newTower.Parent = workspace
	
	print("Torre " .. towerName .. " spawnada para " .. player.Name .. " em " .. tostring(position) .. " com rotação " .. tostring(rotation) .. "°")
end

-- Conecta o evento
placeTowerEvent.OnServerEvent:Connect(spawnTower)]]></ProtectedString>
