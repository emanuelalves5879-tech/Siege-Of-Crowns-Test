				<ProtectedString name="Source"><![CDATA[local module = {}

-- Configurações do Castelo
local CASTLE_MAX_HEALTH = 500
local CASTLE_HEALTH = CASTLE_MAX_HEALTH

-- Referências
local castelo1 = game.Workspace.cenario["Cenário"].Castelo1
local billboardGui = castelo1.BillboardGui
local healthBar = billboardGui.Frame.Background.HealthBar
local healthText = billboardGui.Frame.Background.HealthText
local titleLabel = billboardGui.Frame.Background.TitleLabel

-- Função para atualizar a barra de vida
local function atualizarBarraVida()
	local healthPercent = CASTLE_HEALTH / CASTLE_MAX_HEALTH
	healthBar.Size = UDim2.new(healthPercent, -4, 0.35, -4)
	
	-- Se a vida chegou a 0, mostra "BASE: DESTROYED" centralizado
	if CASTLE_HEALTH <= 0 then
		-- Esconde a barra de vida
		healthBar.Size = UDim2.new(0, 0, 0, 0)
		healthBar.Visible = false
		
		-- Mostra texto centralizado "BASE: DESTROYED"
		healthText.Text = "BASE: DESTROYED"
		healthText.Size = UDim2.new(1, 0, 1, 0)
		healthText.Position = UDim2.new(0, 0, 0, 0)
		healthText.TextSize = 14
		healthText.TextColor3 = Color3.fromRGB(255, 50, 50)
		healthText.BackgroundTransparency = 1
		healthText.TextStrokeTransparency = 0.5
		
		-- Esconde o título
		titleLabel.Text = ""
	else
		healthText.Text = string.format("%d/%d", CASTLE_HEALTH, CASTLE_MAX_HEALTH)
		titleLabel.Text = "Base"
		titleLabel.TextSize = 14
		titleLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
	
		-- Mudar cor baseado na vida
		if healthPercent > 0.6 then
			healthBar.BackgroundColor3 = Color3.fromRGB(50, 200, 50) -- Verde
		elseif healthPercent > 0.3 then
			healthBar.BackgroundColor3 = Color3.fromRGB(255, 200, 0) -- Amarelo
		else
			healthBar.BackgroundColor3 = Color3.fromRGB(200, 50, 50) -- Vermelho
		end
	end
end

-- Função para causar dano ao castelo
function module.TakeDamage(damage)
	if CASTLE_HEALTH <= 0 then return end
	
	CASTLE_HEALTH = math.max(0, CASTLE_HEALTH - damage)
	atualizarBarraVida()
	
	print(string.format("[Castelo] Recebeu %d de dano. Vida restante: %d/%d", damage, CASTLE_HEALTH, CASTLE_MAX_HEALTH))
	
	if CASTLE_HEALTH <= 0 then
		print("[Castelo] DESTRUÍDO!")
		-- Aqui você pode adicionar lógica de game over
	end
end

-- Função para obter a vida atual
function module.GetHealth()
	return CASTLE_HEALTH, CASTLE_MAX_HEALTH
end

-- Inicializar barra de vida
atualizarBarraVida()

return module
]]></ProtectedString>
